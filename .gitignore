## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Xx]64/
[Xx]86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv]isualStudioTester/

# JetBrains Rider
.idea/
*.sln.DotSettings.user
*.iml

# NuGet Packages
packages/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio 2017 AutoGenerated files
Generated\ Files/

# MSTest test Results
TestResults/
[Bb]uildLog.htm

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework 6 (Commonly used legacy targets)
*.Migrations.Metadata.resX

# Entity Framework Core
*.Migrations.Metadata.cs
*.Migrations.Designer.cs

# Entity Framework Core migrations SQL script
*.sql

# Entity Framework Core design-time tool output
*.Migrations.cs

# EF Core Power Tools
*.efpt.config.json

# DNX
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCop.Cache

# CodeAnalysis
*.CodeAnalysisLog.xml
*.lastcodeanalysistitle.txt

# ReSharper is a trademark of JetBrains
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode
.JustCode

# TeamCity
_TeamCity*

# Omoni
.omni

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.bak

# Microsoft Fakes
FakesAssemblies/

# GhostDoc
*.GhostDoc.xml

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Visual Studio 2015 Analyzer
*.cache/

# Others
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs

# Including .folder_state.json based on project configuration
.folder_state.json

# OS files
.DS_Store
Thumbs.db